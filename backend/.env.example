# Montage Backend — Environment Variables
# Copy to .env and fill in values

# PostgreSQL (local Docker)
DATABASE_URL=*** Auth
JWT_SECRET=m...y
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# DeepSeek API
DEEPSEEK_API_KEY=*** Image APIs
PEXELS_API_KEY=*** Server
API_HOST=0.0.0.0
API_PORT=8000

# Stripe (stub)
STRIPE_SECRET_KEY=*** Logging
LOG_LEVEL=INFO
